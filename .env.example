ENVIRONMENT=dev
PROJECT_NAME=Tier 4 Architecture
API_V1_STR=/api/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tier4
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
REQUEST_ID_HEADER=x-request-id
MAX_REQUEST_SIZE_BYTES=2097152
UPLOAD_DIR=./uploads
PASSWORD_RESET_TOKEN_TTL_MINUTES=15
EMAIL_BACKEND=console
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=no-reply@example.com
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin123!
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=dev-stripe-webhook-secret
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=dev-paypal-webhook-secret
JOB_QUEUE_BACKEND=memory
